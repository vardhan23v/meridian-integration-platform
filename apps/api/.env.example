# ──────────────────────────────────────────────
# Meridian Integration Platform — Backend .env
# ──────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql://meridian:meridian_pass@localhost:5432/meridian_db

# Redis
REDIS_URL=redis://localhost:6379

# Kafka (Redpanda in Docker)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=meridian-integration-platform

# JWT Authentication
JWT_SECRET=meridian-dev-jwt-secret-change-in-production-minimum-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=8h

# SAP Connection (Simulated)
SAP_HOST=10.0.0.50
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=MERIDIAN_INT
SAP_MAX_RFC_CONNECTIONS=50

# FinSight API (Simulated)
FINSIGHT_API_URL=http://localhost:3000/api/v1/mock/finsight
FINSIGHT_API_KEY=finsight-dev-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:4000
