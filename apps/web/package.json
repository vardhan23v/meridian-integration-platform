{
  "name": "@meridian/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "clean": "node -e \"const fs=require('fs');const p='.next';if(fs.existsSync(p)){fs.rmSync(p,{recursive:true,force:true,maxRetries:5,retryDelay:100})}\"",
    "prebuild": "npm run clean",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@meridian/shared": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
