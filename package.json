{
  "name": "meridian-integration-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise SAP S/4HANA ↔ FinSight Financial Analytics Integration Platform",
  "author": "Meridian Manufacturing Ltd.",
  "license": "MIT",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @meridian/* run dev",
    "dev:api": "pnpm --filter @meridian/api run dev",
    "dev:web": "pnpm --filter @meridian/web run dev",
    "build": "pnpm --filter @meridian/* run build",
    "lint": "pnpm --filter @meridian/* run lint",
    "typecheck": "pnpm --filter @meridian/* run typecheck",
    "db:generate": "pnpm --filter @meridian/api run db:generate",
    "db:migrate": "pnpm --filter @meridian/api run db:migrate",
    "db:seed": "pnpm --filter @meridian/api run db:seed",
    "clean": "pnpm --filter @meridian/* run clean"
  }
}
